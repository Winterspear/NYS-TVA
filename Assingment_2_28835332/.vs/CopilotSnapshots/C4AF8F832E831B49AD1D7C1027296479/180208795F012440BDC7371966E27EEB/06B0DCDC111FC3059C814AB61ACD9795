<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Register</title>
        <link rel="stylesheet" href="css/style.css" />
    </head>
    <body>
        <header>
            <div class="container">
                <div class="header-content">
                    <h1>Register</h1>
                    <nav>
                        <a href="home.html">Home</a>
                        <a href="userportal.html">User Portal</a>
                        <a href="adminportal.html">Admin Portal</a>
                    </nav>
                </div>
            </div>
        </header>
        <main>
            <section class="auth-section">
                <div class="container">
                    <div class="auth-box">
                        <h2>Create Account</h2>
                        <form id="register-form">
                            <label for="reg-forename">Forename:</label>
                            <input type="text" id="reg-forename" name="forename" required>
                            <label for="reg-surname">Surname:</label>
                            <input type="text" id="reg-surname" name="surname" required>
                            <label for="reg-email">Email:</label>
                            <input type="email" id="reg-email" name="email" required>
                            <label for="reg-password">Password:</label>
                            <input type="password" id="reg-password" name="password" minlength="8"
                                   required>
                            <label for="reg-confirm">Confirm Password:</label>
                            <input type="password" id="reg-confirm" name="confirm" minlength="8"
                                   required>
                            <label for="reg-licence">Licence number:</label>
                            <input type="text" id="reg-licence" name="licence" required>
                            <label for="reg-dateofbirth">Date of Birth:</label>
                            <input type="date" id="reg-dateofbirth" name="dateofbirth" required>
                            <label for="reg-addressL1">Address Line 1:</label>
                            <input type="text" id="reg-addressL1" name="addressL1" required>
                            <label for="reg-addressL2">Address Line 2:</label>
                            <input type="text" id="reg-addressL2" name="addressL2">
                            <label for="reg-city">City:</label>
                            <input type="text" id="reg-city" name="city" required>
                            <label for="reg-state">State:</label>
                            <input type="text" id="reg-state" name="state" required>
                            <label for="reg-zip">ZIP Code:</label>
                            <input type="text" id="reg-zip" name="zip" required>
                            <label for="reg-vehicle">Vehicle Registration:</label>
                            <input type="text" id="reg-vehicle" name="vehicle" required>
                            <label for="reg-phone">Phone Number:</label>
                            <input type="tel" id="reg-phone" name="phone" required>
                            <button type="submit" class="btn-primary">Register</button>
                        </form>
                        <p class="auth-link">Already have an account? <a href="userportal.html">Login here</a></p>
                    </div>
                </div>
            </section>
        </main>
        <footer>
            <p>&copy; 2026 New York Traffic Violations. All rights reserved.</p>
        </footer>
</body>
</html>